<Window x:Class="Proficient.Forms.ElecPanelUtilFrm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proficient.Forms"
        mc:Ignorable="d"
        Title="EntryForm" Height="600" Width="600" WindowStyle="None" AllowsTransparency="True" MouseDown="Window_MouseDown" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary Source="FormStyles.xaml"/>
    </Window.Resources>
    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45" />
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" FontWeight="Bold" Content="✖" Margin="0,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="8" Width="25" Height="25"  Click="CloseButton_Click"/>
            <DataGrid Grid.Row="1">
                
            </DataGrid>
            
        </Grid>
    </Border>
</Window>
