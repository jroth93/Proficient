<Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Proficient"
    x:Class="Proficient.Forms.Follower"
    mc:Ignorable="d"
    
    WindowStyle="None"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    Background="Transparent" 
    Topmost="True" 
    AllowsTransparency="True" 
    Foreground="White"
    
    Closed="Window_Closed">

    <Window.Resources>
        <ResourceDictionary Source="FormStyles.xaml"/>
    </Window.Resources>

    <Border BorderThickness="0" CornerRadius="5" IsHitTestVisible="False">
        <StackPanel  Name="wrapper" x:FieldModifier="public" Margin="0,0,0,0">
            <Label Content="" Name="lbl1" x:FieldModifier="public" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>

</Window>
