<Window x:Class="Proficient.Forms.EntryForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proficient.Forms"
        mc:Ignorable="d"
        Title="EntryForm" Height="150" Width="600" WindowStyle="None" AllowsTransparency="True" MouseDown="Window_MouseDown" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary Source="FormStyles.xaml"/>
    </Window.Resources>
    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Label x:FieldModifier="public" x:Name="Label" Grid.Row="0" Content="testing"  Margin="10,5,10,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <TextBox x:FieldModifier="public" Background="#FF777777" Foreground="White"  x:Name="TextBox" Grid.Row="1" Text="testing" Height="20" Margin="50,0,50,0" VerticalAlignment="Top"/>
            <Grid Grid.Row="2" Margin="5,0,5,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Margin="5" Content="OK" Click="OkButton_Click"/>
                <Button Grid.Column="2" Margin="5" Content="Cancel" Click="CancelButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
